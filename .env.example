# ── Database (Postgres) ───────────────────────────────────────────────
# Local dev (Docker): matches docker-compose.yml. Run `docker compose up -d`.
DATABASE_URL="postgres://qazquiz:qazquiz@localhost:5432/qazquiz"
# Production (Neon): use the *pooled* connection string, e.g.
# DATABASE_URL="postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/qazquiz?sslmode=require"

# ── Redis (Upstash) ───────────────────────────────────────────────────
REDIS_URL="https://xxx.upstash.io"
REDIS_TOKEN="xxxxxxxx"

# ── Auth (Better Auth) ────────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# ── Socket server ─────────────────────────────────────────────────────
SOCKET_SERVER_PORT=3001
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
