# ── Kotlin backend (apps/api) → Postgres ──────────────────────────────
# The Kotlin API is the only thing that talks to Postgres. Local dev uses
# the Docker Postgres from docker-compose.yml. In prod, point it at Neon.
SPRING_DATASOURCE_URL="jdbc:postgresql://localhost:5432/qazquiz"
DB_USER="qazquiz"
DB_PASSWORD="qazquiz"

# ── Node socket-server → Kotlin API ───────────────────────────────────
# Where the socket server fetches questions from (no DB access in Node).
QUESTIONS_API_URL="http://localhost:8080"

# ── Redis (Upstash) — optional, for multi-instance live scores ────────
REDIS_TCP_URL=""

# ── Socket server / web ───────────────────────────────────────────────
SOCKET_SERVER_PORT=3001
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
